# Application
APP_NAME=intelligence-service
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=3004

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Database
DATABASE_URL=postgresql://admin:coredb123@core-postgres:5432/core_db?schema=public
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ML Models
MODEL_PATH=./models_artifacts
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=10000


LLM_DEPLOYMENT_MODE=groq

# === Groq Configuration ===
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b                
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.1

MODAL_ENDPOINT=                        
MODAL_API_TOKEN=                       
MODAL_MODEL=Qwen/Qwen2.5-7B-Instruct
MODAL_KEEP_WARM=0                     

# LLM Performance Settings
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120                  
LLM_REQUEST_TIMEOUT=60           
LLM_BATCH_SIZE=8                 

# === LTR Configuration (LightGBM) ===
LTR_MODEL_PATH=./models_artifacts/lightgbm_ranker.txt
LTR_FEATURE_CACHE_TTL=3600       
LTR_TOP_K=20                     
LTR_BATCH_SIZE=100               

# LightGBM Training Hyperparameters
LTR_NUM_LEAVES=31
LTR_MAX_DEPTH=6
LTR_LEARNING_RATE=0.1
LTR_NUM_ITERATIONS=100
LTR_OBJECTIVE=lambdarank         
LTR_METRIC=ndcg                  

# === Feature Engineering for Recommendations ===
# User behavior features
USER_HISTORY_WINDOW_DAYS=30      
USER_MAX_INTERACTIONS=100       

# Place features
PLACE_MIN_REVIEWS=3              
PLACE_FRESHNESS_DECAY=0.95       

# Context features
ENABLE_TIME_FEATURES=true        
ENABLE_LOCATION_FEATURES=true    
ENABLE_SOCIAL_FEATURES=true      

# === Model Performance & Optimization ===
# Model warm-up
WARMUP_ON_STARTUP=true           
WARMUP_REQUESTS=5              

# Caching strategy
CACHE_LLM_RESPONSES=true         
CACHE_EMBEDDINGS=true            
CACHE_FEATURES=true              
CACHE_TTL_LLM=86400              
CACHE_TTL_EMBEDDINGS=604800      
CACHE_TTL_FEATURES=3600          