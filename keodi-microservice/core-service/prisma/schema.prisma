// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  engineType      = "binary"
  binaryTargets   = ["native"]
  previewFeatures = ["postgresqlExtensions"]
  transpile       = true
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model User {
  id             Int             @id
  phoneNumber    String?         @unique @map("phone_number") @db.VarChar(12)
  firstName      String?         @map("first_name") @db.VarChar(50)
  lastName       String?         @map("last_name") @db.VarChar(50)
  dateOfBirth    DateTime?       @map("date_of_birth")
  picture        String?
  userAttributes UserAttribute[]
  userActions    UserActions[]
  reviews        Reviews[]

  @@map("users")
}

model Place {
  id              String                               @id
  name            String
  altName         String?
  amenity         String?
  brand           String?
  cuisine         String?
  street          String?
  houseNumber     String?
  phone           String?
  openingHours    String?
  internetAccess  String?
  takeaway        Boolean?
  wheelchair      Boolean?
  operator        String?
  checkDate       DateTime?
  createdAt       DateTime                             @default(now())
  updatedAt       DateTime                             @updatedAt
  geom            Unsupported("geography(Point,4326)")
  placeAttributes PlaceAttribute[]
  userActions     UserActions[]
  reviews         Reviews[]

  @@map("places")
}

model Attribute {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  placeAttributes PlaceAttribute[]
  userAttributes  UserAttribute[]

  @@map("attributes")
}

model PlaceAttribute {
  placeId     String @map("place_id")
  attributeId Int    @map("attribute_id")
  score       Float

  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([placeId, attributeId])
  @@map("place_attributes")
}

model UserAttribute {
  userId      Int   @map("user_id")
  attributeId Int   @map("attribute_id")
  score       Float

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([userId, attributeId])
  @@map("user_attributes")
}

model UserActions {
  id        BigInt   @id @default(autoincrement())
  userId    Int      @map("user_id")
  placeId   String   @map("place_id")
  action    String
  score     Float
  timestamp DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Reviews {
  id        BigInt   @id @default(autoincrement())
  userId    Int      @map("user_id")
  fullName  String   @map("full_name")
  placeId   String   @map("place_id")
  rating    Int
  comment   String?
  timestamp DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
}
