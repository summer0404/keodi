// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, unaccent]
}

enum PlaceImageType {
  FEATURE
  COVER
  GALLERY
}

enum UserImageType {
  PICTURE
  GALLERY
}

enum UserActionType {
  CLICK
  RATE_1
  RATE_2
  RATE_3
  RATE_4
  RATE_5
  READ_REVIEWS
  FAVORITE
  GET_DIRECTION
}

enum OwnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id          String    @id
  username    String    @unique @db.VarChar(20)
  phoneNumber String?   @unique @map("phone_number") @db.VarChar(12)
  firstName   String?   @map("first_name") @db.VarChar(50)
  lastName    String?   @map("last_name") @db.VarChar(50)
  dateOfBirth DateTime? @map("date_of_birth")
  pictureUrl  String?   @map("picture_url")

  userImages         UserImage[]
  userAttributes     UserAttribute[]
  userActions        UserAction[]
  reviews            Review[]
  userCategories     UserCategory[]
  places             Place[]
  favorites          Favorite[]
  sessionMemberships GroupSessionMember[]
  searches           Search[]
  sentRequests       FriendRequest[]      @relation("SentRequests")
  receivedRequests   FriendRequest[]      @relation("ReceivedRequests")
  friendships        Friendship[]         @relation("UserFriendships")
  friendsOf          Friendship[]         @relation("FriendFriendships")
  groupSessions      GroupSession[]       @relation("CreatedSessions")
  setting            UserSetting?
  ownerApplication   OwnerApplication?

  @@map("users")
}

model OwnerApplication {
  id                String                 @id @default(cuid())
  userId            String                 @unique @map("user_id")
  businessName      String                 @map("business_name")
  businessPhone     String                 @map("business_phone")
  businessAddress   String                 @map("business_address")
  taxId             String                 @map("tax_id")
  businessWebsite   String?                @map("business_website")
  proofDocumentUrls String[]               @map("proof_document_urls")
  status            OwnerApplicationStatus @default(PENDING)
  rejectionReason   String?                @map("rejection_reason")
  reviewedAt        DateTime?              @map("reviewed_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_applications")
}

model Image {
  id  String @id @default(cuid())
  url String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userImages   UserImage[]
  placeImages  PlaceImage[]
  reviewImages ReviewImage[]

  @@map("images")
}

model UserImage {
  userId  String        @map("user_id")
  imageId String        @map("image_id")
  type    UserImageType @default(GALLERY)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([userId, imageId])
  @@map("user_images")
}

model PlaceImage {
  placeId String         @map("place_id")
  imageId String         @map("image_id")
  type    PlaceImageType @default(GALLERY)

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([placeId, imageId])
  @@map("place_images")
}

model ReviewImage {
  reviewId String @map("review_id")
  imageId  String @map("image_id")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  image    Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([reviewId, imageId])
  @@map("review_images")
}

model Place {
  id              String  @id @default(cuid())
  fromGoogle      Boolean @default(false) @map("from_google")
  name            String
  description     String?
  rating          Float
  googleMapLink   String  @map("google_map_link")
  website         String?
  phoneNumber     String? @map("phone_number")
  featureImageUrl String? @map("feature_image_url")
  ownerId         String? @map("owner_id")

  latitude        Float
  longitude       Float
  fullAddress     String?                     @map("full_address")
  ward            String?
  street          String?
  city            String?
  countryCode     String?                     @map("country_code")
  embeddingTitle  Unsupported("vector(384)")? @map("embedding_title")
  embeddingFull   Unsupported("vector(384)")? @map("embedding_full")
  ftsSearchVector Unsupported("tsvector")?    @map("fts_search_vector")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  placeAttributes        PlaceAttribute[]
  userActions            UserAction[]
  reviews                Review[]
  placeImages            PlaceImage[]
  openingHours           OpeningHour[]
  placeCategories        PlaceCategory[]
  owner                  User?                   @relation(fields: [ownerId], references: [id])
  favorites              Favorite[]
  sessionVotes           SessionVote[]
  wonGroupSessions       GroupSession[]          @relation("SessionWinningPlace")
  groupSessionCandidates GroupSessionCandidate[]

  @@index([latitude, longitude])
  @@index([ftsSearchVector], type: Gin, map: "places_fts_vector_idx")
  @@map("places")
}

model OpeningHour {
  id        String @id @default(cuid())
  placeId   String @map("place_id")
  dayOfWeek Int    @map("day_of_week")

  openTime  DateTime? @map("open_time") @db.Time
  closeTime DateTime? @map("close_time") @db.Time

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("opening_hours")
}

model Attribute {
  id              String           @id @default(cuid())
  name            String           @unique
  placeAttributes PlaceAttribute[]
  userAttributes  UserAttribute[]

  @@map("attributes")
}

model Category {
  id           String  @id @default(cuid())
  name         String  @unique
  isSelectable Boolean @default(false) @map("is_selectable")

  placeCategories        PlaceCategory[]
  userCategories         UserCategory[]
  groupSessionCategories GroupSessionCategory[]

  @@map("categories")
}

model PlaceCategory {
  placeId    String  @map("place_id")
  categoryId String  @map("category_id")
  isMain     Boolean @default(false) @map("is_main")

  place    Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([placeId, categoryId])
  @@map("place_categories")
}

model PlaceAttribute {
  placeId     String @map("place_id")
  attributeId String @map("attribute_id")
  score       Float  @default(0)
  reviewCount Int    @default(0) @map("review_count")

  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([placeId, attributeId])
  @@map("place_attributes")
}

model UserCategory {
  userId            String   @map("user_id")
  categoryId        String   @map("category_id")
  isOnboardSelected Boolean  @default(false) @map("is_onboard_selected")
  lastInteractedAt  DateTime @default(now()) @updatedAt @map("last_interacted_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_categories")
}

model UserAttribute {
  userId      String   @map("user_id")
  attributeId String   @map("attribute_id")
  score       Float    @default(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([userId, attributeId])
  @@map("user_attributes")
}

model UserAction {
  id        BigInt         @id @default(autoincrement())
  userId    String         @map("user_id")
  placeId   String         @map("place_id")
  action    UserActionType
  createdAt DateTime       @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("user_actions")
}

model Review {
  id                String  @id @default(cuid())
  placeId           String  @map("place_id")
  userId            String? @map("user_id")
  fromGoogle        Boolean @default(false) @map("from_google")
  reviewerName      String  @map("reviewer_name")
  reviewerPicture   String? @map("reviewer_picture")
  rating            Int
  text              String?
  originalLanguage  String? @map("original_language")
  sentimentAnalyzed Boolean @default(false) @map("sentiment_analyzed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images ReviewImage[]

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Favorite {
  userId  String @map("user_id")
  placeId String @map("place_id")

  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("favorites")
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String              @map("sender_id")
  receiverId String              @map("receiver_id")
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friendship {
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@id([userId, friendId])
  @@map("friendships")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VoteStatus {
  OPEN
  FINALIZED
}

model SessionVote {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  memberId    String   @unique @map("member_id")
  placeId     String   @map("place_id")
  isFinalized Boolean  @default(false) @map("is_finalized")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session GroupSession       @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  member  GroupSessionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  place   Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("session_votes")
}

model GroupSession {
  sessionId      String             @id @default(cuid()) @map("session_id")
  createdBy      String             @map("created_by")
  shareCode      String             @unique @map("share_code")
  createdAt      DateTime           @default(now()) @map("created_at")
  searchRadius   Float              @default(5) @map("search_radius")
  status         GroupSessionStatus @default(ACTIVE)
  voteStatus     VoteStatus         @default(OPEN) @map("vote_status")
  finalizedAt    DateTime?          @map("finalized_at")
  closeAt        DateTime?          @map("close_at")
  winningPlaceId String?            @map("winning_place_id")

  creator      User   @relation("CreatedSessions", fields: [createdBy], references: [id], onDelete: Cascade)
  winningPlace Place? @relation("SessionWinningPlace", fields: [winningPlaceId], references: [id], onDelete: SetNull)

  members                GroupSessionMember[]
  votes                  SessionVote[]
  selectedCategories     GroupSessionCategory[]
  groupSessionCandidates GroupSessionCandidate[]

  @@map("group_sessions")
}

model GroupSessionCategory {
  sessionId  String   @map("session_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  session  GroupSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  category Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([sessionId, categoryId])
  @@map("group_session_categories")
}

enum GroupSessionStatus {
  ACTIVE
  CLOSED
}

model GroupSessionMember {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String?  @map("user_id")
  guestId   String?  @map("guest_id")
  nickname  String?  @db.VarChar(50)
  joinedAt  DateTime @default(now()) @map("joined_at")

  session GroupSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  vote                   SessionVote?
  groupSessionCandidates GroupSessionCandidate[]

  @@unique([sessionId, userId])
  @@unique([sessionId, guestId])
  @@map("group_session_members")
}

model Search {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  rawQuery      String   @map("raw_query")
  extractedTerm String?  @map("extracted_term")
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("searches")
}

model GroupSessionCandidate {
  sessionId String   @map("session_id")
  placeId   String   @map("place_id")
  addedBy   String   @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  session GroupSession       @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  place   Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)
  member  GroupSessionMember @relation(fields: [addedBy], references: [id], onDelete: Cascade)

  @@id([sessionId, placeId])
  @@map("group_session_candidates")
}

model UserSetting {
  userId String @id @map("user_id")

  shareLocation         Boolean           @default(true) @map("share_location")
  profileVisibility     ProfileVisibility @default(PUBLIC) @map("profile_visibility")
  notifyGroupInvites    Boolean           @default(true) @map("notify_group_invites")
  notifyVotingResults   Boolean           @default(true) @map("notify_voting_results")
  notifyNearbyPlaces    Boolean           @default(true) @map("notify_nearby_places")
  notifyRecommendations Boolean           @default(true) @map("notify_recommendations")
  defaultSearchRadius   SearchRadius      @default(KM_5) @map("default_search_radius")
  defaultMinRating      MinRating         @default(ABOVE_3) @map("default_min_rating")
  language              AppLanguage       @default(VI)
  darkMode              Boolean           @default(false) @map("dark_mode")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum SearchRadius {
  KM_2
  KM_5
  KM_10
  KM_20
}

enum MinRating {
  ABOVE_1
  ABOVE_2
  ABOVE_3
  ABOVE_4
  FIVE_STAR
}

enum AppLanguage {
  VI
  EN
}
