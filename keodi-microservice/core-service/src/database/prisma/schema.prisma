// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlaceImageType {
  FEATURE
  COVER
  GALLERY
}

enum UserImageType {
  PICTURE
  GALLERY
}

enum UserActionType {
  CLICK
  RATE_1
  RATE_2
  RATE_3
  RATE_4
  RATE_5
  READ_REVIEWS
  FAVORITE
  GET_DIRECTION
}

model User {
  id          String    @id
  phoneNumber String?   @unique @map("phone_number") @db.VarChar(12)
  firstName   String?   @map("first_name") @db.VarChar(50)
  lastName    String?   @map("last_name") @db.VarChar(50)
  dateOfBirth DateTime? @map("date_of_birth")
  pictureUrl  String?   @map("picture_url")

  userImages         UserImage[]
  userAttributes     UserAttribute[]
  userActions        UserAction[]
  reviews            Review[]
  userCategories     UserCategory[]
  places             Place[]
  favorites          Favorite[]
  sessionMemberships GroupSessionMember[]
  searches           Search[]

  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friendships      Friendship[]    @relation("UserFriendships")
  friendsOf        Friendship[]    @relation("FriendFriendships")
  groupSessions    GroupSession[]  @relation("CreatedSessions")

  @@map("users")
}

model Image {
  id  String @id @default(cuid())
  url String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userImages   UserImage[]
  placeImages  PlaceImage[]
  reviewImages ReviewImage[]

  @@map("images")
}

model UserImage {
  userId  String        @map("user_id")
  imageId String        @map("image_id")
  type    UserImageType @default(GALLERY)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([userId, imageId])
  @@map("user_images")
}

model PlaceImage {
  placeId String         @map("place_id")
  imageId String         @map("image_id")
  type    PlaceImageType @default(GALLERY)

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([placeId, imageId])
  @@map("place_images")
}

model ReviewImage {
  reviewId String @map("review_id")
  imageId  String @map("image_id")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  image    Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([reviewId, imageId])
  @@map("review_images")
}

model Place {
  id              String  @id @default(cuid())
  fromGoogle      Boolean @default(false) @map("from_google")
  name            String
  description     String?
  rating          Float
  googleMapLink   String  @map("google_map_link")
  website         String?
  phoneNumber     String? @map("phone_number")
  featureImageUrl String? @map("feature_image_url")
  ownerId         String? @map("owner_id")

  latitude    Float
  longitude   Float
  fullAddress String? @map("full_address")
  ward        String?
  street      String?
  city        String?
  countryCode String? @map("country_code")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  placeAttributes  PlaceAttribute[]
  userActions      UserAction[]
  reviews          Review[]
  placeImages      PlaceImage[]
  openingHours     OpeningHour[]
  placeCategories  PlaceCategory[]
  owner            User?            @relation(fields: [ownerId], references: [id])
  favorites        Favorite[]
  sessionVotes     SessionVote[]
  wonGroupSessions GroupSession[]   @relation("SessionWinningPlace")

  @@index([latitude, longitude])
  @@map("places")
}

model OpeningHour {
  id        String @id @default(cuid())
  placeId   String @map("place_id")
  dayOfWeek Int    @map("day_of_week")

  openTime  DateTime @map("open_time") @db.Time
  closeTime DateTime @map("close_time") @db.Time

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("opening_hours")
}

model Attribute {
  id              String           @id @default(cuid())
  name            String           @unique
  placeAttributes PlaceAttribute[]
  userAttributes  UserAttribute[]

  @@map("attributes")
}

model Category {
  id              String          @id @default(cuid())
  name            String          @unique
  isSelectable    Boolean         @default(false) @map("is_selectable")
  placeCategories PlaceCategory[]
  userCategories  UserCategory[]

  @@map("categories")
}

model PlaceCategory {
  placeId    String  @map("place_id")
  categoryId String  @map("category_id")
  isMain     Boolean @default(false) @map("is_main")

  place    Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([placeId, categoryId])
  @@map("place_categories")
}

model PlaceAttribute {
  placeId     String @map("place_id")
  attributeId String @map("attribute_id")
  score       Float  @default(0)
  reviewCount Int    @default(0) @map("review_count")

  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([placeId, attributeId])
  @@map("place_attributes")
}

model UserCategory {
  userId            String   @map("user_id")
  categoryId        String   @map("category_id")
  isOnboardSelected Boolean  @default(false) @map("is_onboard_selected")
  lastInteractedAt  DateTime @default(now()) @updatedAt @map("last_interacted_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_categories")
}

model UserAttribute {
  userId      String   @map("user_id")
  attributeId String   @map("attribute_id")
  score       Float    @default(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([userId, attributeId])
  @@map("user_attributes")
}

model UserAction {
  id        BigInt         @id @default(autoincrement())
  userId    String         @map("user_id")
  placeId   String         @map("place_id")
  action    UserActionType
  createdAt DateTime       @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("user_actions")
}

model Review {
  id                String  @id @default(cuid())
  placeId           String  @map("place_id")
  userId            String? @map("user_id")
  fromGoogle        Boolean @default(false) @map("from_google")
  reviewerName      String  @map("reviewer_name")
  reviewerPicture   String? @map("reviewer_picture")
  rating            Int
  text              String?
  originalLanguage  String? @map("original_language")
  sentimentAnalyzed Boolean @default(false) @map("sentiment_analyzed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images ReviewImage[]

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Favorite {
  userId  String @map("user_id")
  placeId String @map("place_id")

  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("favorites")
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String              @map("sender_id")
  receiverId String              @map("receiver_id")
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friendship {
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@id([userId, friendId])
  @@map("friendships")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VoteStatus {
  OPEN
  FINALIZED
}

model SessionVote {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  memberId    String   @unique @map("member_id")
  placeId     String   @map("place_id")
  isFinalized Boolean  @default(false) @map("is_finalized")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session GroupSession       @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  member  GroupSessionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  place   Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("session_votes")
}

model GroupSession {
  sessionId      String             @id @default(cuid()) @map("session_id")
  createdBy      String             @map("created_by")
  shareCode      String             @unique @map("share_code")
  createdAt      DateTime           @default(now()) @map("created_at")
  status         GroupSessionStatus @default(ACTIVE)
  voteStatus     VoteStatus         @default(OPEN) @map("vote_status")
  finalizedAt    DateTime?          @map("finalized_at")
  winningPlaceId String?            @map("winning_place_id")

  creator      User   @relation("CreatedSessions", fields: [createdBy], references: [id], onDelete: Cascade)
  winningPlace Place? @relation("SessionWinningPlace", fields: [winningPlaceId], references: [id], onDelete: SetNull)

  members GroupSessionMember[]
  votes   SessionVote[]

  @@map("group_sessions")
}

enum GroupSessionStatus {
  ACTIVE
  CLOSED
}

model GroupSessionMember {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  userId    String?  @map("user_id") //null for guest
  guestId   String?  @map("guest_id")
  nickname  String?  @db.VarChar(50) //nickname for guest
  joinedAt  DateTime @default(now()) @map("joined_at")

  session GroupSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  vote SessionVote?

  @@unique([sessionId, userId])
  @@unique([sessionId, guestId])
  @@map("group_session_members")
}

model Search {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  extractedTerm String   @map("extracted_term")
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("searches")
}
